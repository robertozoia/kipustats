# Path to the SQLite database file
DATABASE_PATH=./data/analytics.db

# Bcrypt hash of the dashboard password.
# Generate one with:
#   echo -n 'yourpassword' | cargo run -- --hash-password
# or with the compiled binary:
#   echo -n 'yourpassword' | blog-analytics-service --hash-password
#
# If not set, the default development password is "admin".
DASHBOARD_PASSWORD_HASH=

# Secret key used to sign session cookies (any random string, 64+ characters recommended).
# Generate one with:
#   openssl rand -hex 32
#
# If not set, a random secret is generated at startup (sessions won't survive restarts).
COOKIE_SECRET=
