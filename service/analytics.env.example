# Dashboard password (plaintext — hashed automatically at startup).
# This is the recommended approach for Docker deployments.
DASHBOARD_PASSWORD=changeme

# Alternatively, you can provide a pre-hashed bcrypt password instead:
# DASHBOARD_PASSWORD_HASH=$2b$12$...
# Generate with: echo -n 'yourpassword' | blog-analytics-service --hash-password
# Note: bcrypt hashes contain $ signs which cause issues with Docker Compose.

# Secret key used to sign session cookies (any random string, 64+ characters recommended).
# Generate with: openssl rand -hex 32
COOKIE_SECRET=
