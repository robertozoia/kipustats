# Dashboard password (plaintext — hashed automatically at startup).
# This is the recommended approach for Docker deployments.
DASHBOARD_PASSWORD=changeme

# Alternatively, you can provide a pre-hashed bcrypt password instead:
# DASHBOARD_PASSWORD_HASH=$2b$12$...
# Generate with: echo -n 'yourpassword' | blog-analytics-service --hash-password
# Note: bcrypt hashes contain $ signs which cause issues with Docker Compose.

# Secret key used to sign session cookies (any random string, 64+ characters recommended).
# Generate with: openssl rand -hex 32
COOKIE_SECRET=

# Shared secret for authenticating event ingestion requests from the worker.
# Must match the AUTH_TOKEN secret configured in the Cloudflare Worker.
# Generate with: openssl rand -hex 32
AUTH_TOKEN=

# Comma-separated list of allowed CORS origins (optional).
# Example: https://yourdomain.com,https://www.yourdomain.com
# CORS_ORIGIN=

# Host directory to mount as the database volume (default: ./analytics-data)
# DATABASE_DIR=./analytics-data

# SQLite database filename (default: analytics.db)
# DATABASE_NAME=analytics.db
